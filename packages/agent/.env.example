# Hot wallet private key (deploys contract + mints NFT)
AGENT_PRIVATE_KEY=0x...

# RPC endpoints
ETHEREUM_MAINNET_RPC_URL=https://...
TENDERLY_FORK_RPC_URL=https://...

# Set to "true" to use Tenderly fork instead of mainnet
USE_TENDERLY=true

# Telegram bot token (from BotFather)
TELEGRAM_BOT_TOKEN=...

# Logging
LOG_DIR=./logs
